<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="defs_cap_sales" targetNamespace="http://probuild/platform">
  <bpmn:process id="Cap_Sales" name="Sales Capability" isExecutable="true">

    <bpmn:startEvent id="Sa_Start" name="Sales invoked">
      <bpmn:outgoing>s_f1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Sa_Check" name="Check inventory">
      <bpmn:extensionElements><zeebe:taskDefinition type="sales-check-inventory" /></bpmn:extensionElements>
      <bpmn:incoming>s_f1</bpmn:incoming>
      <bpmn:outgoing>s_f2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Sa_InStock" name="In stock?" default="s_out">
      <bpmn:incoming>s_f2</bpmn:incoming>
      <bpmn:outgoing>s_in</bpmn:outgoing>
      <bpmn:outgoing>s_out</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Sa_Quote" name="Prepare quote">
      <bpmn:extensionElements><zeebe:taskDefinition type="sales-prepare-quote" /></bpmn:extensionElements>
      <bpmn:incoming>s_in</bpmn:incoming>
      <bpmn:outgoing>s_f3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="Sa_EndQuoted" name="Quote issued">
      <bpmn:incoming>s_f3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:serviceTask id="Sa_Backorder" name="Raise backorder">
      <bpmn:extensionElements><zeebe:taskDefinition type="sales-raise-backorder" /></bpmn:extensionElements>
      <bpmn:incoming>s_out</bpmn:incoming>
      <bpmn:outgoing>s_f4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="Sa_EndBackorder" name="Backorder raised">
      <bpmn:incoming>s_f4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="s_f1" sourceRef="Sa_Start" targetRef="Sa_Check" />
    <bpmn:sequenceFlow id="s_f2" sourceRef="Sa_Check" targetRef="Sa_InStock" />
    <bpmn:sequenceFlow id="s_in" name="in stock" sourceRef="Sa_InStock" targetRef="Sa_Quote">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=inStock = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s_out" name="out of stock" sourceRef="Sa_InStock" targetRef="Sa_Backorder" />
    <bpmn:sequenceFlow id="s_f3" sourceRef="Sa_Quote" targetRef="Sa_EndQuoted" />
    <bpmn:sequenceFlow id="s_f4" sourceRef="Sa_Backorder" targetRef="Sa_EndBackorder" />
  </bpmn:process>
</bpmn:definitions>
