<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="defs_journey" targetNamespace="http://probuild/platform">

  <bpmn:collaboration id="Collab_ProBuild">
    <bpmn:participant id="Pool_Customer" name="Customer" processRef="Journey_Customer" />
    <bpmn:participant id="Pool_FinTrust" name="FinTrust UK (Finance Partner)" processRef="Partner_FinTrust" />
    <bpmn:participant id="Pool_FixPro" name="FixPro Ltd (Maintenance Partner)" processRef="Partner_FixPro" />
    <bpmn:messageFlow id="mf_fin_req" sourceRef="J_SendFinance" targetRef="FT_Start" />
    <bpmn:messageFlow id="mf_fin_settle_a" sourceRef="FT_SettleApproved" targetRef="J_CatchFinance" />
    <bpmn:messageFlow id="mf_fin_settle_r" sourceRef="FT_SettleRejected" targetRef="J_CatchFinance" />
    <bpmn:messageFlow id="mf_svc_req" sourceRef="J_SendService" targetRef="FX_Start" />
    <bpmn:messageFlow id="mf_svc_done" sourceRef="FX_Settle" targetRef="J_CatchService" />
  </bpmn:collaboration>

  <!-- ============ CUSTOMER ORCHESTRATOR ============ -->
  <bpmn:process id="Journey_Customer" name="Customer Journey (Orchestrator)" isExecutable="true">

    <bpmn:startEvent id="J_Start" name="Customer arrives">
      <bpmn:extensionElements><zeebe:formDefinition formId="form_choose_service" /></bpmn:extensionElements>
      <bpmn:outgoing>j_f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="J_Init" name="Open journey">
      <bpmn:extensionElements><zeebe:taskDefinition type="journey-init" /></bpmn:extensionElements>
      <bpmn:incoming>j_f1</bpmn:incoming><bpmn:outgoing>j_f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="J_Route" name="Which service?" default="j_buy">
      <bpmn:incoming>j_f2</bpmn:incoming>
      <bpmn:outgoing>j_card</bpmn:outgoing>
      <bpmn:outgoing>j_hire</bpmn:outgoing>
      <bpmn:outgoing>j_buy</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Trade Card branch -->
    <bpmn:userTask id="J_ApplyCard" name="Apply for Trade Card">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_apply_card" /></bpmn:extensionElements>
      <bpmn:incoming>j_card</bpmn:incoming><bpmn:outgoing>j_f3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:callActivity id="J_CallLoyalty" name="Loyalty: enrol">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Cap_Loyalty" propagateAllChildVariables="true" />
        <zeebe:ioMapping><zeebe:input source="=&quot;ENROL&quot;" target="loyaltyMode" /></zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>j_f3</bpmn:incoming><bpmn:outgoing>j_f4</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:userTask id="J_ConfirmCard" name="Trade Card confirmation">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_confirm_card" /></bpmn:extensionElements>
      <bpmn:incoming>j_f4</bpmn:incoming><bpmn:outgoing>j_f5</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Buy branch -->
    <bpmn:userTask id="J_Browse" name="Browse products">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_browse_products" /></bpmn:extensionElements>
      <bpmn:incoming>j_buy</bpmn:incoming><bpmn:outgoing>j_f6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:callActivity id="J_CallSales" name="Sales: quote">
      <bpmn:extensionElements><zeebe:calledElement processId="Cap_Sales" propagateAllChildVariables="true" /></bpmn:extensionElements>
      <bpmn:incoming>j_f6</bpmn:incoming><bpmn:outgoing>j_f7</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="J_QuoteGate" name="In stock?" default="j_backorder">
      <bpmn:incoming>j_f7</bpmn:incoming>
      <bpmn:outgoing>j_quoted</bpmn:outgoing>
      <bpmn:outgoing>j_backorder</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="J_Backorder" name="Backorder notice">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_backorder_ack" /></bpmn:extensionElements>
      <bpmn:incoming>j_backorder</bpmn:incoming><bpmn:outgoing>j_f8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="J_ReviewQuote" name="Review quote">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_review_quote" /></bpmn:extensionElements>
      <bpmn:incoming>j_quoted</bpmn:incoming><bpmn:outgoing>j_f9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="J_AcceptGate" name="Quote accepted?" default="j_reject">
      <bpmn:incoming>j_f9</bpmn:incoming>
      <bpmn:outgoing>j_accept</bpmn:outgoing>
      <bpmn:outgoing>j_reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="J_Payment" name="Choose payment method">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_make_payment" /></bpmn:extensionElements>
      <bpmn:incoming>j_accept</bpmn:incoming><bpmn:outgoing>j_f10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="J_PayGate" name="Finance?" default="j_direct">
      <bpmn:incoming>j_f10</bpmn:incoming>
      <bpmn:outgoing>j_finance</bpmn:outgoing>
      <bpmn:outgoing>j_direct</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="J_SendFinance" name="Request finance">
      <bpmn:extensionElements><zeebe:taskDefinition type="publish-finance-request" /></bpmn:extensionElements>
      <bpmn:incoming>j_finance</bpmn:incoming><bpmn:outgoing>j_f11</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="J_CatchFinance" name="Finance settled">
      <bpmn:incoming>j_f11</bpmn:incoming><bpmn:outgoing>j_f12</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Msg_FinanceSettled" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="J_FinGate" name="Finance approved?" default="j_findecline">
      <bpmn:incoming>j_f12</bpmn:incoming>
      <bpmn:outgoing>j_finapprove</bpmn:outgoing>
      <bpmn:outgoing>j_findecline</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="J_PayMerge">
      <bpmn:incoming>j_direct</bpmn:incoming>
      <bpmn:incoming>j_finapprove</bpmn:incoming>
      <bpmn:outgoing>j_f13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="J_CallWarehouse" name="Warehouse: fulfil">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Cap_Warehouse" propagateAllChildVariables="true" />
        <zeebe:ioMapping><zeebe:input source="=&quot;FULFIL&quot;" target="fulfilMode" /></zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>j_f13</bpmn:incoming><bpmn:outgoing>j_f14</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="J_CallAccrue" name="Loyalty: accrue">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Cap_Loyalty" propagateAllChildVariables="true" />
        <zeebe:ioMapping><zeebe:input source="=&quot;ACCRUE&quot;" target="loyaltyMode" /></zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>j_f14</bpmn:incoming><bpmn:outgoing>j_f15</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:userTask id="J_ConfirmPurchase" name="Purchase confirmation">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_confirm_purchase" /></bpmn:extensionElements>
      <bpmn:incoming>j_f15</bpmn:incoming><bpmn:outgoing>j_f16</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Hire branch -->
    <bpmn:userTask id="J_CheckAvail" name="Check tool availability">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_check_avail" /></bpmn:extensionElements>
      <bpmn:incoming>j_hire</bpmn:incoming><bpmn:outgoing>j_h1</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:callActivity id="J_CallHire" name="Hire: book">
      <bpmn:extensionElements><zeebe:calledElement processId="Cap_Hire" propagateAllChildVariables="true" /></bpmn:extensionElements>
      <bpmn:incoming>j_h1</bpmn:incoming><bpmn:outgoing>j_h2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="J_HireGate" name="Booked?" default="j_unavail">
      <bpmn:incoming>j_h2</bpmn:incoming>
      <bpmn:outgoing>j_booked</bpmn:outgoing>
      <bpmn:outgoing>j_unavail</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="J_HireUnavail" name="Tool unavailable">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_hire_unavail" /></bpmn:extensionElements>
      <bpmn:incoming>j_unavail</bpmn:incoming><bpmn:outgoing>j_h3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="J_PayDeposit" name="Pay deposit">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_pay_deposit" /></bpmn:extensionElements>
      <bpmn:incoming>j_booked</bpmn:incoming><bpmn:outgoing>j_h4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="J_UseTool" name="Use tool">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_use_tool" /></bpmn:extensionElements>
      <bpmn:incoming>j_h4</bpmn:incoming><bpmn:outgoing>j_h5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="J_ReturnTool" name="Return tool">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_return_tool" /></bpmn:extensionElements>
      <bpmn:incoming>j_h5</bpmn:incoming><bpmn:outgoing>j_h6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:callActivity id="J_CallWhReturn" name="Warehouse: inspect return">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Cap_Warehouse" propagateAllChildVariables="true" />
        <zeebe:ioMapping><zeebe:input source="=&quot;RETURN&quot;" target="fulfilMode" /></zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>j_h6</bpmn:incoming><bpmn:outgoing>j_h7</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="J_ServiceGate" name="Needs maintenance?" default="j_noservice">
      <bpmn:incoming>j_h7</bpmn:incoming>
      <bpmn:outgoing>j_service</bpmn:outgoing>
      <bpmn:outgoing>j_noservice</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="J_SendService" name="Request FixPro service">
      <bpmn:extensionElements><zeebe:taskDefinition type="publish-service-request" /></bpmn:extensionElements>
      <bpmn:incoming>j_service</bpmn:incoming><bpmn:outgoing>j_h8</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="J_CatchService" name="Tool serviced">
      <bpmn:incoming>j_h8</bpmn:incoming><bpmn:outgoing>j_h9</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Msg_ServiceCompleted" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="J_HireMerge">
      <bpmn:incoming>j_noservice</bpmn:incoming>
      <bpmn:incoming>j_h9</bpmn:incoming>
      <bpmn:outgoing>j_h10</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Terminal merges -->
    <bpmn:exclusiveGateway id="J_ServedMerge">
      <bpmn:incoming>j_f5</bpmn:incoming>
      <bpmn:incoming>j_f16</bpmn:incoming>
      <bpmn:incoming>j_h10</bpmn:incoming>
      <bpmn:outgoing>j_served</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="J_End" name="Customer served">
      <bpmn:incoming>j_served</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="J_CancelMerge">
      <bpmn:incoming>j_f8</bpmn:incoming>
      <bpmn:incoming>j_reject</bpmn:incoming>
      <bpmn:incoming>j_findecline</bpmn:incoming>
      <bpmn:incoming>j_h3</bpmn:incoming>
      <bpmn:outgoing>j_cancelled</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="J_EndCancel" name="Customer cancelled">
      <bpmn:incoming>j_cancelled</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="j_f1" sourceRef="J_Start" targetRef="J_Init" />
    <bpmn:sequenceFlow id="j_f2" sourceRef="J_Init" targetRef="J_Route" />
    <bpmn:sequenceFlow id="j_card" name="apply card" sourceRef="J_Route" targetRef="J_ApplyCard">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=serviceType = "apply_card"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="j_hire" name="hire" sourceRef="J_Route" targetRef="J_CheckAvail">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=serviceType = "hire"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="j_buy" name="buy" sourceRef="J_Route" targetRef="J_Browse" />
    <bpmn:sequenceFlow id="j_f3" sourceRef="J_ApplyCard" targetRef="J_CallLoyalty" />
    <bpmn:sequenceFlow id="j_f4" sourceRef="J_CallLoyalty" targetRef="J_ConfirmCard" />
    <bpmn:sequenceFlow id="j_f5" sourceRef="J_ConfirmCard" targetRef="J_ServedMerge" />
    <bpmn:sequenceFlow id="j_f6" sourceRef="J_Browse" targetRef="J_CallSales" />
    <bpmn:sequenceFlow id="j_f7" sourceRef="J_CallSales" targetRef="J_QuoteGate" />
    <bpmn:sequenceFlow id="j_quoted" name="quoted" sourceRef="J_QuoteGate" targetRef="J_ReviewQuote">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=salesOutcome = "QUOTED"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="j_backorder" name="backorder" sourceRef="J_QuoteGate" targetRef="J_Backorder" />
    <bpmn:sequenceFlow id="j_f8" sourceRef="J_Backorder" targetRef="J_CancelMerge" />
    <bpmn:sequenceFlow id="j_f9" sourceRef="J_ReviewQuote" targetRef="J_AcceptGate" />
    <bpmn:sequenceFlow id="j_accept" name="accept" sourceRef="J_AcceptGate" targetRef="J_Payment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=quoteAccepted = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="j_reject" name="reject" sourceRef="J_AcceptGate" targetRef="J_CancelMerge" />
    <bpmn:sequenceFlow id="j_f10" sourceRef="J_Payment" targetRef="J_PayGate" />
    <bpmn:sequenceFlow id="j_finance" name="finance" sourceRef="J_PayGate" targetRef="J_SendFinance">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=paymentMethod = "finance"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="j_direct" name="card / cash" sourceRef="J_PayGate" targetRef="J_PayMerge" />
    <bpmn:sequenceFlow id="j_f11" sourceRef="J_SendFinance" targetRef="J_CatchFinance" />
    <bpmn:sequenceFlow id="j_f12" sourceRef="J_CatchFinance" targetRef="J_FinGate" />
    <bpmn:sequenceFlow id="j_finapprove" name="approved" sourceRef="J_FinGate" targetRef="J_PayMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=financeApproved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="j_findecline" name="declined" sourceRef="J_FinGate" targetRef="J_CancelMerge" />
    <bpmn:sequenceFlow id="j_f13" sourceRef="J_PayMerge" targetRef="J_CallWarehouse" />
    <bpmn:sequenceFlow id="j_f14" sourceRef="J_CallWarehouse" targetRef="J_CallAccrue" />
    <bpmn:sequenceFlow id="j_f15" sourceRef="J_CallAccrue" targetRef="J_ConfirmPurchase" />
    <bpmn:sequenceFlow id="j_f16" sourceRef="J_ConfirmPurchase" targetRef="J_ServedMerge" />
    <bpmn:sequenceFlow id="j_h1" sourceRef="J_CheckAvail" targetRef="J_CallHire" />
    <bpmn:sequenceFlow id="j_h2" sourceRef="J_CallHire" targetRef="J_HireGate" />
    <bpmn:sequenceFlow id="j_booked" name="booked" sourceRef="J_HireGate" targetRef="J_PayDeposit">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hireOutcome = "BOOKED"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="j_unavail" name="unavailable" sourceRef="J_HireGate" targetRef="J_HireUnavail" />
    <bpmn:sequenceFlow id="j_h3" sourceRef="J_HireUnavail" targetRef="J_CancelMerge" />
    <bpmn:sequenceFlow id="j_h4" sourceRef="J_PayDeposit" targetRef="J_UseTool" />
    <bpmn:sequenceFlow id="j_h5" sourceRef="J_UseTool" targetRef="J_ReturnTool" />
    <bpmn:sequenceFlow id="j_h6" sourceRef="J_ReturnTool" targetRef="J_CallWhReturn" />
    <bpmn:sequenceFlow id="j_h7" sourceRef="J_CallWhReturn" targetRef="J_ServiceGate" />
    <bpmn:sequenceFlow id="j_service" name="needs service" sourceRef="J_ServiceGate" targetRef="J_SendService">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=needsMaintenance = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="j_noservice" name="ready to hire" sourceRef="J_ServiceGate" targetRef="J_HireMerge" />
    <bpmn:sequenceFlow id="j_h8" sourceRef="J_SendService" targetRef="J_CatchService" />
    <bpmn:sequenceFlow id="j_h9" sourceRef="J_CatchService" targetRef="J_HireMerge" />
    <bpmn:sequenceFlow id="j_h10" sourceRef="J_HireMerge" targetRef="J_ServedMerge" />
    <bpmn:sequenceFlow id="j_served" sourceRef="J_ServedMerge" targetRef="J_End" />
    <bpmn:sequenceFlow id="j_cancelled" sourceRef="J_CancelMerge" targetRef="J_EndCancel" />
  </bpmn:process>

  <!-- ============ FINTRUST PARTNER ============ -->
  <bpmn:process id="Partner_FinTrust" name="FinTrust UK" isExecutable="true">
    <bpmn:startEvent id="FT_Start" name="Finance request received">
      <bpmn:outgoing>ft_f1</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Msg_FinanceRequested" />
    </bpmn:startEvent>
    <bpmn:businessRuleTask id="FT_Assess" name="Assess creditworthiness">
      <bpmn:extensionElements><zeebe:calledDecision decisionId="finance_assessment" resultVariable="financeResult" /></bpmn:extensionElements>
      <bpmn:incoming>ft_f1</bpmn:incoming><bpmn:outgoing>ft_f2</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="FT_Review" name="Review &amp; confirm decision">
      <bpmn:extensionElements><zeebe:userTask /><zeebe:formDefinition formId="form_finance_review" /></bpmn:extensionElements>
      <bpmn:incoming>ft_f2</bpmn:incoming><bpmn:outgoing>ft_f3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="FT_Decision" name="Approved?" default="ft_reject">
      <bpmn:incoming>ft_f3</bpmn:incoming>
      <bpmn:outgoing>ft_approve</bpmn:outgoing>
      <bpmn:outgoing>ft_reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="FT_Transfer" name="Transfer funds">
      <bpmn:extensionElements><zeebe:taskDefinition type="finance-transfer" /></bpmn:extensionElements>
      <bpmn:incoming>ft_approve</bpmn:incoming><bpmn:outgoing>ft_f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="FT_SettleApproved" name="Notify approval">
      <bpmn:extensionElements><zeebe:taskDefinition type="publish-finance-settled" /></bpmn:extensionElements>
      <bpmn:incoming>ft_f4</bpmn:incoming><bpmn:outgoing>ft_f5</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="FT_EndApproved" name="Funds transferred">
      <bpmn:incoming>ft_f5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="FT_Reject" name="Record rejection">
      <bpmn:extensionElements><zeebe:taskDefinition type="finance-reject" /></bpmn:extensionElements>
      <bpmn:incoming>ft_reject</bpmn:incoming><bpmn:outgoing>ft_f6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="FT_SettleRejected" name="Notify rejection">
      <bpmn:extensionElements><zeebe:taskDefinition type="publish-finance-settled" /></bpmn:extensionElements>
      <bpmn:incoming>ft_f6</bpmn:incoming><bpmn:outgoing>ft_f7</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="FT_EndRejected" name="Application rejected">
      <bpmn:incoming>ft_f7</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="ft_f1" sourceRef="FT_Start" targetRef="FT_Assess" />
    <bpmn:sequenceFlow id="ft_f2" sourceRef="FT_Assess" targetRef="FT_Review" />
    <bpmn:sequenceFlow id="ft_f3" sourceRef="FT_Review" targetRef="FT_Decision" />
    <bpmn:sequenceFlow id="ft_approve" name="approve" sourceRef="FT_Decision" targetRef="FT_Transfer">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=financeApproved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="ft_reject" name="reject" sourceRef="FT_Decision" targetRef="FT_Reject" />
    <bpmn:sequenceFlow id="ft_f4" sourceRef="FT_Transfer" targetRef="FT_SettleApproved" />
    <bpmn:sequenceFlow id="ft_f5" sourceRef="FT_SettleApproved" targetRef="FT_EndApproved" />
    <bpmn:sequenceFlow id="ft_f6" sourceRef="FT_Reject" targetRef="FT_SettleRejected" />
    <bpmn:sequenceFlow id="ft_f7" sourceRef="FT_SettleRejected" targetRef="FT_EndRejected" />
  </bpmn:process>

  <!-- ============ FIXPRO PARTNER ============ -->
  <bpmn:process id="Partner_FixPro" name="FixPro Ltd" isExecutable="true">
    <bpmn:startEvent id="FX_Start" name="Service request received">
      <bpmn:outgoing>fx_f1</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Msg_ServiceRequested" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="FX_Collect" name="Collect tools">
      <bpmn:extensionElements><zeebe:taskDefinition type="fixpro-collect" /></bpmn:extensionElements>
      <bpmn:incoming>fx_f1</bpmn:incoming><bpmn:outgoing>fx_f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="FX_Triage" name="Triage batch">
      <bpmn:extensionElements><zeebe:calledDecision decisionId="maintenance_triage" resultVariable="triageResult" /></bpmn:extensionElements>
      <bpmn:incoming>fx_f2</bpmn:incoming><bpmn:outgoing>fx_f3</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="FX_Service" name="Service &amp; PAT test">
      <bpmn:extensionElements><zeebe:taskDefinition type="fixpro-service" /></bpmn:extensionElements>
      <bpmn:incoming>fx_f3</bpmn:incoming><bpmn:outgoing>fx_f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="FX_Report" name="Generate report &amp; invoice">
      <bpmn:extensionElements><zeebe:taskDefinition type="fixpro-report" /></bpmn:extensionElements>
      <bpmn:incoming>fx_f4</bpmn:incoming><bpmn:outgoing>fx_f5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="FX_Settle" name="Return serviced tools">
      <bpmn:extensionElements><zeebe:taskDefinition type="publish-service-completed" /></bpmn:extensionElements>
      <bpmn:incoming>fx_f5</bpmn:incoming><bpmn:outgoing>fx_f6</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="FX_EndServiced" name="Batch complete">
      <bpmn:incoming>fx_f6</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Weekly scheduled batch (timer-triggered) -->
    <bpmn:startEvent id="FX_TimerStart" name="Weekly maintenance sweep">
      <bpmn:outgoing>fx_t1</bpmn:outgoing>
      <bpmn:timerEventDefinition><bpmn:timeCycle>R/P7D</bpmn:timeCycle></bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:serviceTask id="FX_Weekly" name="Sweep service bay">
      <bpmn:extensionElements><zeebe:taskDefinition type="fixpro-weekly-batch" /></bpmn:extensionElements>
      <bpmn:incoming>fx_t1</bpmn:incoming><bpmn:outgoing>fx_t2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="FX_EndWeekly" name="Sweep done">
      <bpmn:incoming>fx_t2</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="fx_f1" sourceRef="FX_Start" targetRef="FX_Collect" />
    <bpmn:sequenceFlow id="fx_f2" sourceRef="FX_Collect" targetRef="FX_Triage" />
    <bpmn:sequenceFlow id="fx_f3" sourceRef="FX_Triage" targetRef="FX_Service" />
    <bpmn:sequenceFlow id="fx_f4" sourceRef="FX_Service" targetRef="FX_Report" />
    <bpmn:sequenceFlow id="fx_f5" sourceRef="FX_Report" targetRef="FX_Settle" />
    <bpmn:sequenceFlow id="fx_f6" sourceRef="FX_Settle" targetRef="FX_EndServiced" />
    <bpmn:sequenceFlow id="fx_t1" sourceRef="FX_TimerStart" targetRef="FX_Weekly" />
    <bpmn:sequenceFlow id="fx_t2" sourceRef="FX_Weekly" targetRef="FX_EndWeekly" />
  </bpmn:process>

  <bpmn:message id="Msg_FinanceRequested" name="finance.requested" />
  <bpmn:message id="Msg_FinanceSettled" name="finance.settled">
